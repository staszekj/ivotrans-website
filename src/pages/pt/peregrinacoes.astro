---

<Layout title="Peregrinações - Ivotrans" lang={lang}>
  <Header lang={lang} currentPath={currentPath} />
  
  <PageHeader 
    title="Peregrinações"
    subtitle="Descubra nossos programas de peregrinacao cuidadosamente desenhados para jornadas com sentido"
    backgroundImage="/images/pilgrimages/krakow-hero.jpg"
  />

  <main class="main-content">
    {itineraries.map((tour) => (
      <Wyjazd
        kraj={tour.title}
        tytul={tour.subtitle}
        miejsca={tour.places}
        transport={tour.transport}
        dni={tour.days}
        pdf={tour.pdf}
        zdjecie={tour.image || transparentPixel}
        jezyk="pt"
      />
    ))}
  </main>
  
  <Footer lang={lang} />
</Layout>

<style>
  .main-content {
    padding-top: 0;
  }
</style>
