---

<Layout title="Peregrinaciones - Ivotrans" lang={lang}>
  <Header lang={lang} currentPath={currentPath} />
  
  <PageHeader 
    title="Peregrinaciones"
    subtitle="Descubra nuestras propuestas de programas de peregrinación, cuidadosamente diseñadas para viajes con sentido"
    backgroundImage="/images/pilgrimages/krakow-hero.jpg"
  />

  <main class="main-content">
    {itineraries.map((tour) => (
      <Wyjazd
        kraj={tour.title}
        tytul={tour.subtitle}
        miejsca={tour.places}
        transport={tour.transport}
        dni={tour.days}
        pdf={tour.pdf}
        zdjecie={tour.image || transparentPixel}
        jezyk="es"
      />
    ))}
  </main>
  
  <Footer lang={lang} />
</Layout>

<style>
  .main-content {
    padding-top: 0;
  }
</style>
