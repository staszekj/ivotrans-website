---

<Layout title="Pellegrinaggi - Ivotrans" lang={lang}>
  <Header lang={lang} currentPath={currentPath} />
  
  <PageHeader 
    title="Pellegrinaggi"
    subtitle="Scoprite le nostre proposte di programmi di pellegrinaggio, pensate con cura per viaggi ricchi di significato"
    backgroundImage="/images/pilgrimages/krakow-hero.jpg"
  />


  <main class="main-content">
    {itineraries.map((tour) => (
      <Wyjazd
        kraj={tour.title}
        tytul={tour.subtitle}
        miejsca={tour.places}
        transport={tour.transport}
        dni={tour.days}
        pdf={tour.pdf}
        zdjecie={tour.image || transparentPixel}
        jezyk="it"
      />
    ))}
  </main>
  
  <Footer lang={lang} />
</Layout>

<style>
  .main-content {
    padding-top: 0;
  }
</style>
